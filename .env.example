# ListMonk API connection
LISTMONK_URL=https://your-listmonk-instance.com
LISTMONK_USER=listmonk
LISTMONK_API_KEY=your-api-key-here

# Dashboard login credentials
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

# Session signing key (leave empty to auto-generate, or set a random string for persistence)
SESSION_SECRET=

# IMAP settings for unsubscribe monitoring
IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USER=your@email.com
IMAP_PASS=your-password
IMAP_USE_SSL=true
